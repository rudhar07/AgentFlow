# ─────────────────────────────────────────────────────────────────────────────
# AgentFlow configuration.
# Copy this file to ".env" and adjust as needed:  cp .env.example .env
# Every value has a sane default, so .env is entirely optional for the
# deterministic agent. An API key is only required for `--mode llm`.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM-vision mode (optional) --------------------------------------------
# Required only when running `python main.py --mode llm`.
ANTHROPIC_API_KEY=
# Model used by the LLM-vision agent. Defaults to the latest Claude Opus.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Target task ------------------------------------------------------------
AGENTFLOW_TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form
AGENTFLOW_NAME_VALUE=AgentFlow Bot
AGENTFLOW_DESCRIPTION_VALUE=Filled automatically by the AgentFlow website automation agent.

# --- Browser behaviour ------------------------------------------------------
AGENTFLOW_BROWSER=chromium          # chromium | firefox | webkit
AGENTFLOW_HEADLESS=false            # true to run without a visible window
AGENTFLOW_SLOW_MO=150               # ms delay between actions (visibility during demos)
AGENTFLOW_VIEWPORT_WIDTH=1280       # 1280x800 keeps screenshots <1.15MP so the
AGENTFLOW_VIEWPORT_HEIGHT=800       # LLM sees coordinates 1:1 with real pixels
AGENTFLOW_TIMEOUT_MS=30000
AGENTFLOW_TYPE_DELAY_MS=30          # ms between keystrokes

# --- LLM-vision agent -------------------------------------------------------
AGENTFLOW_MAX_STEPS=20              # safety cap on the LLM action loop
